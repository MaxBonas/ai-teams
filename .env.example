# Core runtime profile
AITEAM_ENV=stage
AITEAM_BROWSER_MODE=playwright
AITEAM_API_KEY=
AITEAM_ENABLE_LIVE_API=0
AITEAM_MAX_PARALLEL_TASKS=1
AITEAM_MAX_PARALLEL_TASKS_STAGE=2
AITEAM_MAX_PARALLEL_TASKS_PROD=1
AITEAM_MIN_PARALLEL_TASKS=1
AITEAM_PARALLEL_AUTOTUNE=0
AITEAM_PARALLEL_TARGET_LATENCY_MS=1200
AITEAM_PARALLEL_MAX_FAILURE_RATE=25
AITEAM_ENFORCE_ROLE_MODEL_PREFERENCES=0
AITEAM_STRICT_ROLE_POLICY_ENVS=prod

# Shared tools root
AITEAM_SHARED_TOOLS_ROOT=C:\Users\Max\Antigravity Projects

# Subscription provider toggles
AITEAM_SUBSCRIPTION_OPENAI_ENABLED=1
AITEAM_SUBSCRIPTION_GOOGLE_ENABLED=1
AITEAM_SUBSCRIPTION_ANTHROPIC_ENABLED=1

# Optional: explicit Pro CLI commands (JSON array or shell-like string)
AITEAM_OPENAI_PRO_COMMAND=["npx","-y","@openai/codex","exec","--skip-git-repo-check","{prompt}"]
# AITEAM_GEMINI_PRO_COMMAND=["npx","-y","@google/gemini-cli","-p","{prompt}"]
# AITEAM_CLAUDE_PRO_COMMAND=["claude","-p","{prompt}"]

# Mark limits/degradation when provider is unavailable
AITEAM_SUBSCRIPTION_OPENAI_LIMIT_REACHED=0
AITEAM_SUBSCRIPTION_GOOGLE_LIMIT_REACHED=0
AITEAM_SUBSCRIPTION_ANTHROPIC_LIMIT_REACHED=0
AITEAM_PROVIDER_OPENAI_DEGRADED=0
AITEAM_PROVIDER_GOOGLE_DEGRADED=0
AITEAM_PROVIDER_ANTHROPIC_DEGRADED=0
AITEAM_PROVIDER_GROQ_DEGRADED=0

# Require API keys for fallback adapters
AITEAM_REQUIRE_API_KEYS=0

# API keys (fill when using real API fallback)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# NotebookLM bridge (optional)
NOTEBOOKLM_NOTEBOOK_ID=
NOTEBOOKLM_API_KEY=
GOOGLE_NOTEBOOKLM_API_KEY=
NOTEBOOKLM_INGEST_ENDPOINT=
# JSON array preferred, supports {payload_path} placeholder
# NOTEBOOKLM_INGEST_COMMAND=["python","-c","import pathlib,sys;print(pathlib.Path(sys.argv[1]).exists())","{payload_path}"]

# Optional: explicit role pools
AITEAM_ROLE_ENGINEER_POOL=eng-1,eng-2,eng-3
AITEAM_ROLE_REVIEWER_POOL=review-1,review-2
AITEAM_ROLE_QA_POOL=qa-1,qa-2

# Optional: mark specific agents unavailable
# AITEAM_AGENT_ENG_2_ENABLED=0
