# =============================================================================
# AI Teams Hybrid Orchestrator — configuracion de entorno
# Copiar a .env y rellenar los valores especificos de la maquina.
# NUNCA commitear .env ni API keys.
# =============================================================================
# Dos maquinas en uso:
#   max-gamingpc  → usuario: she__   → ruta base: C:\Users\she__\Documents\Antigravity Projects\
#   ORCH-01       → usuario: she__   → ruta base: C:\Users\she__\Documents\Antigravity Projects\
#                   (misma estructura via Syncthing; venv siempre local, no sincronizado)
# =============================================================================

# ── Perfil de runtime ─────────────────────────────────────────────────────────
AITEAM_ENV=dev
AITEAM_BROWSER_MODE=basic
AITEAM_API_KEY=
AITEAM_ENABLE_LIVE_API=1
AITEAM_REQUIRE_LIVE_MODE=1

# ── Paralelismo del equipo ────────────────────────────────────────────────────
# Recomendacion operativa: dev=2, stage=2, prod=2-3 (ver docs/BATCH2_SPEC.md)
# Las barreras de Batch 2 (claim_task guard + checkpoint) protegen la seguridad.
# Ajustar por maquina si una tiene mas recursos que la otra.
AITEAM_MAX_PARALLEL_TASKS=2
AITEAM_MAX_PARALLEL_TASKS_DEV=2
AITEAM_MAX_PARALLEL_TASKS_STAGE=2
AITEAM_MAX_PARALLEL_TASKS_PROD=2
AITEAM_MIN_PARALLEL_TASKS=1
AITEAM_PARALLEL_AUTOTUNE=0
AITEAM_PARALLEL_TARGET_LATENCY_MS=1200
AITEAM_PARALLEL_MAX_FAILURE_RATE=25

# ── Rutas especificas de maquina ──────────────────────────────────────────────
# max-gamingpc (she__):
AITEAM_SHARED_TOOLS_ROOT=C:\Users\she__\Documents\Antigravity Projects
# ORCH-01 (she__ via Syncthing — misma ruta si el usuario coincide):
# AITEAM_SHARED_TOOLS_ROOT=C:\Users\she__\Documents\Antigravity Projects

# ── Providers de suscripcion ──────────────────────────────────────────────────
# Activar solo los que esten disponibles y sanos en esta maquina.
# Estado 2026-03-26: openai OK, google OK, anthropic CAIDO (creditos agotados).
AITEAM_SUBSCRIPTION_OPENAI_ENABLED=1
AITEAM_SUBSCRIPTION_GOOGLE_ENABLED=1
AITEAM_SUBSCRIPTION_ANTHROPIC_ENABLED=1

# Deshabilitar si el provider alcanzo su limite mensual:
AITEAM_SUBSCRIPTION_OPENAI_LIMIT_REACHED=0
AITEAM_SUBSCRIPTION_GOOGLE_LIMIT_REACHED=0
AITEAM_SUBSCRIPTION_ANTHROPIC_LIMIT_REACHED=0

# Deshabilitar si el provider esta degradado o caido:
AITEAM_PROVIDER_OPENAI_DEGRADED=0
AITEAM_PROVIDER_GOOGLE_DEGRADED=0
# Poner a 1 si los creditos de Anthropic siguen agotados:
AITEAM_PROVIDER_ANTHROPIC_DEGRADED=0
AITEAM_PROVIDER_GROQ_DEGRADED=0

# ── Comandos CLI de providers Pro (smoke test + inferencia via CLI) ────────────
# max-gamingpc: Codex CLI y Gemini CLI instalados via npx
AITEAM_OPENAI_PRO_COMMAND=["npx","-y","@openai/codex","exec","--skip-git-repo-check","{prompt}"]
AITEAM_GEMINI_PRO_COMMAND=["cmd","/c","set GEMINI_API_KEY=%GOOGLE_API_KEY% && npx -y @google/gemini-cli {prompt}"]
# Claude Code CLI: descomentar cuando los creditos esten recargados
# AITEAM_CLAUDE_PRO_COMMAND=["npx","-y","@anthropic-ai/claude-code","-p","{prompt}"]

# ORCH-01: mismos comandos si Codex y Gemini CLI estan instalados
# (verificar con: npx -y @openai/codex --version)

# ── API keys (para inferencia REST directa con AITEAM_ENABLE_LIVE_API=1) ───────
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Exigir que los adapters de API tengan key configurada antes de usarlos:
AITEAM_REQUIRE_API_KEYS=0

# ── Modelo local (Ollama) ─────────────────────────────────────────────────────
# max-gamingpc: Ollama instalado, modelo aiteam-qwen-coder:14b disponible
# ORCH-01: verificar instalacion con: ollama list
# Ver Modelfile en: runtime/ollama/Modelfile.aiteam-qwen-coder
OLLAMA_HOST=http://localhost:11434

# ── Politica de modelos ───────────────────────────────────────────────────────
AITEAM_ENFORCE_ROLE_MODEL_PREFERENCES=0
AITEAM_STRICT_ROLE_POLICY_ENVS=prod

# ── Pools de agentes por rol ──────────────────────────────────────────────────
# Ajustar segun cuantos agentes paralelos se quieran por rol.
AITEAM_ROLE_ENGINEER_POOL=eng-1,eng-2,eng-3
AITEAM_ROLE_REVIEWER_POOL=review-1,review-2
AITEAM_ROLE_QA_POOL=qa-1,qa-2

# Deshabilitar agentes especificos si es necesario:
# AITEAM_AGENT_ENG_2_ENABLED=0

# ── Bridges opcionales ────────────────────────────────────────────────────────
# NotebookLM (opcional, no requerido para el equipo base):
NOTEBOOKLM_NOTEBOOK_ID=
NOTEBOOKLM_API_KEY=
GOOGLE_NOTEBOOKLM_API_KEY=
NOTEBOOKLM_INGEST_ENDPOINT=
