{
  "name": "ide-frontend",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 9483",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:size": "node scripts/check-module-limits.mjs",
    "lint:bundle": "node scripts/check-bundle-limits.mjs",
    "typecheck": "tsc -b",
    "test:unit": "vitest run",
    "check": "npm run lint && npm run lint:css && npm run lint:size && npm run test:unit && npm run build && npm run lint:bundle && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium-desktop --project=chromium-mobile",
    "test:e2e:matrix": "playwright test e2e/cockpit-panels.spec.ts",
    "test:e2e:orientation": "playwright test e2e/orientation-flow.spec.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.26.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "stylelint": "^17.14.1",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
