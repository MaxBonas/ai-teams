    {"id":"circuit_breaker","weight":2,"required":true,"patterns":["circuit.breaker|cortacircuit"]},
    {"id":"bounded_retries","weight":2,"patterns":["backoff|jitter|reintentos?.{0,20}(m[aá]ximo|l[ií]mite|acot)"]},
    {"id":"cost_cap","weight":2,"required":true,"patterns":["cap.{0,20}cost|l[ií]mite.{0,20}cost|presupuesto"]},
    {"id":"quality_guard","weight":2,"patterns":["quality|calidad|capacidad.{0,20}modelo|equivalencia"]},
    {"id":"observability","weight":1,"patterns":["telemetr|m[eé]trica|cost_events|run_events"]},
