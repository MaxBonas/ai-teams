{
  "id": "auth_migration_causal_v4",
  "max_compression_ratio": 0.30,
  "criteria": [
    {"id": "jwt_rs256", "kind": "decision", "patterns": ["JWT.{0,20}RS256"], "required": true},
    {"id": "dual_validation_24h", "kind": "decision", "patterns": ["doble validaci[oó]n.{0,40}24 ?(h|horas)"], "required": true},
    {"id": "legacy_kid_gate", "kind": "constraint", "patterns": ["legacy_kid_hits.{0,40}(0|cero).{0,30}(2 ?h|dos horas)"], "required": true},
    {"id": "evidence", "kind": "evidence", "patterns": ["42 (tests )?passed"], "required": true},
    {"id": "next_owner", "kind": "owner", "patterns": ["Engineer.{0,80}rollback_keys\\.py"], "required": true},
    {"id": "review_acceptance", "kind": "acceptance", "patterns": ["Reviewer.{0,40}dry-run|dry-run.{0,40}Reviewer"], "required": true},
    {"id": "regional_cache_risk", "kind": "risk", "patterns": ["cach[eé]s\\s+regionales.{0,50}15 ?(min|minutos)"], "required": true},
    {"id": "escalation_threshold", "kind": "escalation", "patterns": ["0[,.]5 ?%.{0,50}401.{0,50}(5 ?min|cinco minutos)|401.{0,50}0[,.]5 ?%.{0,50}(5 ?min|cinco minutos)"], "required": true},
    {"id": "scope", "kind": "scope", "patterns": ["fuera de (scope|alcance).{0,70}(sesiones|proveedor de identidad)"], "required": true}
  ]
}
