      "commands": [
        "git"
      ]
    },
    {
      "id": "powershell",
      "requirement": "required_on_windows",
      "minimum_version": "5.1",
      "recommended_version": "7",
      "version_args": [
        "-NoProfile",
        "-Command",
        "$PSVersionTable.PSVersion.ToString()"
      ],
      "commands": [
        "pwsh.exe",
        "powershell.exe"
      ]
    }
  ],
  "live_run_contract": {
    "minimum": "Al menos un adapter Lead-capable debe estar instalado, autenticado, compatible y verde.",
    "primary_options": [
      "codex_subscription",
      "antigravity_subscription",
      "openai_api",
      "gemini_api",
      "anthropic_api"
    ],
    "rules": [
      "Encontrar un CLI no demuestra autenticación ni health.",
      "No se exige instalar todos los canales.",
      "OpenCode Zen, Ollama y LM Studio no satisfacen por sí solos el mínimo Lead-capable vigente.",
      "API y suscripción son canales independientes."
    ]
  },
  "adapters": [
    {
      "id": "codex_subscription",
      "cli_id": "codex",
      "setup_class": "primary_option",
      "commands": [
        "codex.cmd",
        "codex"
      ],
      "version_args": [
        "--version"
      ],
      "install": {
        "windows": "powershell -ExecutionPolicy Bypass -c \"irm https://chatgpt.com/codex/install.ps1 | iex\"",
        "portable_alternative": "npm install -g @openai/codex"
      },
      "authentication": {
        "human_required": true,
        "command": "codex login",
        "mode": "ChatGPT o API key administrada por Codex"
      },
      "automatic_install": false
    },
    {
      "id": "antigravity_subscription",
      "cli_id": "agy",
      "setup_class": "primary_option",
      "commands": [
        "agy.exe",
        "agy"
      ],
      "version_args": [
        "--version"
      ],
      "install": {
        "windows": "irm https://antigravity.google/cli/install.ps1 | iex"
      },
      "authentication": {
        "human_required": true,
        "command": "agy",
        "mode": "keyring del sistema con fallback a Google Sign-In"
      },
      "automatic_install": false
    },
    {
      "id": "opencode_zen_free",
      "cli_id": "opencode",
      "setup_class": "optional_economy",
      "commands": [
        "opencode.cmd",
        "opencode"
      ],
      "version_args": [
        "--version"
      ],
      "install": {
        "windows": "npm install -g opencode-ai@latest"
      },
      "authentication": {
        "human_required": true,
        "command": "opencode auth login --provider opencode",
        "mode": "API key personal de OpenCode Zen",
        "notes": "Precio cero de un modelo no implica gateway anónimo; la oferta y sus límites son temporales."
      },
      "data_policy": "non_confidential_only",
      "automatic_install": false
    },
    {
      "id": "ollama",
      "cli_id": "ollama",
      "setup_class": "optional_local",
      "commands": [
        "ollama.exe",
        "ollama"
      ],
      "version_args": [
        "--version"
      ],
      "authentication": {
        "human_required": false,
        "mode": "local"
      },
      "automatic_install": false
    },
    {
      "id": "lmstudio",
      "cli_id": "lms",
      "setup_class": "optional_local",
      "commands": [
        "lms.exe",
        "lms"
