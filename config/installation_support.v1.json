        "python",
        "py"
      ]
    },
    {
      "id": "node",
      "requirement": "required",
      "minimum_version": "22",
      "recommended_version": "24",
      "version_args": [
        "--version"
      ],
      "commands": [
        "node"
      ],
      "notes": "Node 20 e inferiores están EOL; 24 es LTS en la fecha del contrato."
    },
    {
      "id": "npm",
      "requirement": "required",
      "minimum_version": "10",
      "recommended_version": "11",
