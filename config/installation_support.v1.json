    "unsupported"
  ],
  "acceptance_contract": {
    "schema_version": "windows_clean_room_acceptance_v1",
    "platform_id": "windows_native_x86_64",
    "workflow": ".github/workflows/windows-clean-room.yml",
    "runner": "windows-latest",
    "required_steps": [
      "source_revision",
      "bootstrap_first",
      "bootstrap_second",
      "installation_audit",
      "start",
      "backend_health",
      "frontend_health",
      "fixture_project_create",
      "stop",
      "ports_released"
    ],
    "promotion_requires": [
      "ok=true",
      "independent_machine=true",
      "promotion_allowed=true",
      "recibo redacted conservado como artefacto"
    ],
    "limits": [
      "No instala ni autentica CLIs de proveedores.",
      "No ejecuta inferencias ni demuestra que un adapter esté verde.",
      "Una ejecución local valida el harness, pero no cuenta como máquina independiente."
    ]
  },
  "distributions": [
    {
      "id": "git_checkout",
      "status": "preview",
      "source": "https://github.com/MaxBonas/ai-teams.git",
      "integrity": "tag o commit SHA explícito",
      "update": "git pull",
      "rollback": "checkout de un tag o commit conocido",
      "notes": "Vía canónica actual; aún no existe una release aceptada en máquina limpia."
    },
    {
      "id": "versioned_release_artifact",
      "status": "planned",
      "channel": "GitHub Release",
      "required_contents": [
        "versión inmutable",
        "checksums SHA-256",
        "SBOM y reporte de licencias",
        "notas de migración",
        "instrucciones de actualización y rollback",
        "test de ausencia de secretos y estado local"
      ],
      "notes": "Debe incluir checksum, SBOM/licencias, notas de migración y rollback."
    },
    {
      "id": "container",
      "status": "planned",
      "notes": "Será opcional y no sustituirá CLIs, sesiones ni keyrings que viven en el host."
    }
  ],
  "platforms": [
