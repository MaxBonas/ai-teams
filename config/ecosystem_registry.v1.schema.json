{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ecosystem_registry_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_status",
    "action_ids",
    "execution_policy",
    "ecosystems",
    "known_gaps"
  ],
  "properties": {
    "schema_version": {"const": "ecosystem_registry_v1"},
    "contract_status": {"enum": ["preview", "verified"]},
    "action_ids": {
      "type": "array",
      "items": {"enum": ["configure", "build", "test", "lint", "typecheck"]},
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detection_mutates",
        "automatic_install",
        "descriptor_only_commands",
        "requires_authorization",
        "cwd_within_workspace",
        "max_timeout_seconds",
        "allowed_env"
      ],
      "properties": {
        "detection_mutates": {"const": false},
        "automatic_install": {"const": false},
        "descriptor_only_commands": {"const": true},
        "requires_authorization": {"const": true},
        "cwd_within_workspace": {"const": true},
        "max_timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "allowed_env": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
          "uniqueItems": true
        }
      }
    },
    "ecosystems": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/ecosystem"}
    },
    "known_gaps": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    }
  },
  "$defs": {
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "candidates", "version_args"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "candidates": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        },
        "version_args": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "runtime_id",
        "argv",
        "selectors",
        "cwd",
        "env",
        "timeout_seconds",
        "required_capability",
        "mutates_workspace",
        "project_script",
        "status"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "runtime_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "argv": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "selectors": {
          "type": "object",
          "additionalProperties": false,
          "required": ["manifests", "globs", "json_script", "content_markers"],
          "properties": {
            "manifests": {"type": "array", "items": {"type": "string"}},
            "globs": {"type": "array", "items": {"type": "string"}},
            "json_script": {"type": ["string", "null"]},
            "content_markers": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "cwd": {"enum": ["workspace", "manifest_dir"]},
        "env": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "required_capability": {"enum": ["build_execute", "test_execute"]},
        "mutates_workspace": {"type": "boolean"},
        "project_script": {"type": "boolean"},
        "status": {"enum": ["legacy_enabled", "planned"]}
      }
    },
    "ecosystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "status",
        "categories",
        "detectors",
        "runtimes",
        "action_dependencies",
        "commands",
        "artifacts"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "label": {"type": "string", "minLength": 1},
        "status": {"enum": ["planned", "preview", "verified", "unsupported"]},
        "categories": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        },
        "detectors": {
          "type": "object",
          "additionalProperties": false,
          "required": ["manifests", "extensions"],
          "properties": {
            "manifests": {
              "type": "array",
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "extensions": {
              "type": "array",
              "items": {"type": "string", "pattern": "^\\.[A-Za-z0-9+_-]+$"},
              "uniqueItems": true
            }
          }
        },
        "runtimes": {
          "type": "array",
          "items": {"$ref": "#/$defs/runtime"}
        },
        "action_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action", "requires"],
            "properties": {
              "action": {"enum": ["configure", "build", "test", "lint", "typecheck"]},
              "requires": {
                "type": "array",
                "items": {"enum": ["configure", "build", "test", "lint", "typecheck"]},
                "minItems": 1,
                "uniqueItems": true
              }
            }
          }
        },
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "required": ["configure", "build", "test", "lint", "typecheck"],
          "properties": {
            "configure": {"type": "array", "items": {"$ref": "#/$defs/command"}},
            "build": {"type": "array", "items": {"$ref": "#/$defs/command"}},
            "test": {"type": "array", "items": {"$ref": "#/$defs/command"}},
            "lint": {"type": "array", "items": {"$ref": "#/$defs/command"}},
            "typecheck": {"type": "array", "items": {"$ref": "#/$defs/command"}}
          }
        },
        "artifacts": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    }
  }
}
