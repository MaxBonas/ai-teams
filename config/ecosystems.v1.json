{
  "schema_version": "ecosystem_registry_v1",
  "contract_status": "preview",
  "action_ids": ["configure", "build", "test", "lint", "typecheck"],
  "execution_policy": {
    "detection_mutates": false,
    "automatic_install": false,
    "descriptor_only_commands": true,
    "requires_authorization": true,
    "cwd_within_workspace": true,
    "max_timeout_seconds": 1200,
    "allowed_env": ["CI", "NO_COLOR", "PYTHONUTF8"]
  },
  "ecosystems": [
    {
      "id": "python",
      "label": "Python",
      "status": "preview",
      "categories": ["backend", "data", "automation"],
      "detectors": {
        "manifests": ["pyproject.toml", "requirements.txt", "setup.py", "pytest.ini", "tox.ini", "noxfile.py"],
        "extensions": [".py", ".pyi"]
      },
      "runtimes": [
        {"id": "python", "candidates": ["python3", "python"], "version_args": ["--version"]}
      ],
      "action_dependencies": [],
      "commands": {
        "configure": [],
        "build": [
          {
            "id": "python_build",
            "runtime_id": "python",
            "argv": ["{runtime}", "-m", "build"],
            "selectors": {"manifests": ["pyproject.toml"], "globs": [], "json_script": null, "content_markers": {}},
            "cwd": "manifest_dir",
            "env": {"PYTHONUTF8": "1"},
            "timeout_seconds": 600,
            "required_capability": "build_execute",
            "mutates_workspace": true,
            "project_script": false,
            "status": "planned"
          }
        ],
        "test": [
          {
            "id": "pytest",
            "runtime_id": "python",
            "argv": ["{runtime}", "-m", "pytest", "-q", "{test_targets}"],
            "selectors": {
              "manifests": ["pytest.ini", "tox.ini", "noxfile.py"],
              "globs": ["test_*.py", "tests/test_*.py", "tests/**/test_*.py", "test/test_*.py", "test/**/test_*.py"],
              "json_script": null,
              "content_markers": {"pyproject.toml": ["pytest"]}
            },
            "cwd": "workspace",
            "env": {"PYTHONUTF8": "1", "NO_COLOR": "1"},
            "timeout_seconds": 600,
            "required_capability": "test_execute",
            "mutates_workspace": false,
            "project_script": false,
            "status": "legacy_enabled"
          }
        ],
        "lint": [
          {
            "id": "ruff",
            "runtime_id": "python",
            "argv": ["{runtime}", "-m", "ruff", "check", "."],
            "selectors": {"manifests": [], "globs": [], "json_script": null, "content_markers": {"pyproject.toml": ["ruff"]}},
            "cwd": "workspace",
            "env": {"PYTHONUTF8": "1", "NO_COLOR": "1"},
            "timeout_seconds": 300,
            "required_capability": "test_execute",
            "mutates_workspace": false,
            "project_script": false,
            "status": "planned"
          }
        ],
        "typecheck": []
      },
      "artifacts": ["dist/*.whl", "dist/*.tar.gz", ".coverage", "htmlcov/**"]
    },
