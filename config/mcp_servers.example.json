{
  "servers": [
    {
      "name": "filesystem_mcp",
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "%USERPROFILE%\\Documents\\Antigravity Projects"
      ],
      "env": {},
      "transport": "stdio",
      "enabled": true,
      "requires_approval": false,
      "source_type": "npm",
      "source": "@modelcontextprotocol/server-filesystem",
      "capabilities": [
        "repo_read",
        "repo_write",
        "external_mcp"
      ],
      "role_targets": [
        "scout",
        "researcher",
        "engineer",
        "qa"
      ],
      "health_status": "unknown",
      "health_reason": "",
      "last_checked": "",
      "bootstrap_source": ""
    },
    {
      "name": "git_mcp",
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "%USERPROFILE%\\Documents\\Antigravity Projects\\Ai_Teams"
      ],
      "env": {},
      "transport": "stdio",
      "enabled": true,
      "requires_approval": false,
      "source_type": "uvx",
      "source": "mcp-server-git",
      "capabilities": [
        "git_status",
        "git_diff",
        "git_log",
        "external_mcp"
      ],
      "role_targets": [
        "scout",
        "engineer",
        "reviewer",
        "team_lead"
      ],
      "health_status": "unknown",
      "health_reason": "",
      "last_checked": "",
      "bootstrap_source": ""
    },
    {
      "name": "playwright_mcp",
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-playwright"
      ],
      "env": {},
      "transport": "stdio",
      "enabled": false,
      "requires_approval": false,
      "source_type": "npm",
      "source": "@modelcontextprotocol/server-playwright",
      "capabilities": [
        "browser_nav",
        "browser_test",
        "external_mcp"
      ],
      "role_targets": [
        "qa",
        "engineer",
        "researcher"
      ],
      "health_status": "unknown",
      "health_reason": "",
      "last_checked": "",
      "bootstrap_source": ""
    }
  ]
}
