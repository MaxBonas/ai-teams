{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MaxBonas/ai-teams/schemas/machine_doctor_remediation.v1.schema.json",
  "title": "machine_doctor_remediation_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "applied",
    "report_sha256",
    "action",
    "execution",
    "receipt_id"
  ],
  "properties": {
    "schema_version": {"const": "machine_doctor_remediation_v1"},
    "mode": {"const": "guided_manual"},
    "applied": {"const": false},
    "report_sha256": {"$ref": "#/$defs/sha256"},
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "description",
        "requires_human",
        "mutates_state",
        "targets"
      ],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "requires_human": {"type": "boolean"},
        "mutates_state": {"type": "boolean"},
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["subject_kind", "subject_id", "diagnostic_code"],
            "properties": {
              "subject_kind": {"type": "string", "minLength": 1},
              "subject_id": {"type": "string", "minLength": 1},
              "diagnostic_code": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {"const": "not_executed"},
        "reason": {"const": "manual_or_future_governed_executor_required"}
      }
    },
    "receipt_id": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
